# SUSTech Mailer SMTP credentials
# Copy this file to ~/.sustech-mailer-smtp.env and fill in your authorization code.
#
# To get an authorization code:
#   1. Log in to exmail.qq.com
#   2. Settings → Mail sending/receiving settings → Enable POP3/IMAP/SMTP
#   3. Settings → Account binding → Generate "client-specific password"

SUSTECH_SMTP_USER=12312411@mail.sustech.edu.cn
SUSTECH_SMTP_PASS=your_authorization_code_here
