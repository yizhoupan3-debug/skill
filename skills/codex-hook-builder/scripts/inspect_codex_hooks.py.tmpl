#!/usr/bin/env python3
"""Inspect Codex hook configuration without modifying files."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
from typing import Any


KNOWN_EVENTS = {
    "SessionStart",
    "UserPromptSubmit",
    "PreToolUse",
    "PermissionRequest",
    "PostToolUse",
    "Stop",
}


def read_text(path: Path) -> str | None:
    try:
        return path.read_text(encoding="utf-8")
    except FileNotFoundError:
        return None


def load_hooks(path: Path) -> dict[str, Any]:
    text = read_text(path)
    if text is None:
        return {"path": str(path), "exists": False}
    try:
        data = json.loads(text)
    except json.JSONDecodeError as exc:
        return {
            "path": str(path),
            "exists": True,
            "valid_json": False,
            "error": f"{exc.msg} at line {exc.lineno}, column {exc.colno}",
        }

    hooks = data.get("hooks")
    events: dict[str, int] = {}
    unknown_events: list[str] = []
    if isinstance(hooks, dict):
        for event, groups in hooks.items():
            if event not in KNOWN_EVENTS:
                unknown_events.append(event)
            events[event] = len(groups) if isinstance(groups, list) else 0

    return {
        "path": str(path),
        "exists": True,
        "valid_json": True,
        "events": events,
        "unknown_events": unknown_events,
    }


def inspect_config(path: Path) -> dict[str, Any]:
    text = read_text(path)
    if text is None:
        return {"path": str(path), "exists": False}
    has_feature = "codex_hooks" in text
    enabled_hint = any(
        marker in text.replace(" ", "")
        for marker in ("codex_hooks=true", "codex_hooks= true")
    )
    return {
        "path": str(path),
        "exists": True,
        "mentions_codex_hooks": has_feature,
        "enabled_hint": enabled_hint,
    }


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--repo",
        default=".",
        help="Repository or project root to inspect. Defaults to the current directory.",
    )
    parser.add_argument(
        "--json",
        action="store_true",
        help="Emit machine-readable JSON.",
    )
    args = parser.parse_args()

    repo = Path(args.repo).expanduser().resolve()
    home = Path(os.environ.get("CODEX_HOME", Path.home() / ".codex")).expanduser()
    locations = {
        "user_config": inspect_config(home / "config.toml"),
        "user_hooks": load_hooks(home / "hooks.json"),
        "project_config": inspect_config(repo / ".codex" / "config.toml"),
        "project_hooks": load_hooks(repo / ".codex" / "hooks.json"),
    }
    summary = {
        "repo": str(repo),
        "codex_home": str(home),
        "locations": locations,
        "next_steps": [
            "Enable [features] codex_hooks = true before relying on hooks.",
            "Validate every hooks.json file before installing new matchers.",
            "Prefer project hooks for repo-specific policy and user hooks for personal defaults.",
        ],
    }

    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        print(f"Repo: {summary['repo']}")
        print(f"Codex home: {summary['codex_home']}")
        for name, details in locations.items():
            marker = "OK" if details.get("exists") else "missing"
            print(f"{name}: {marker} - {details['path']}")
            if details.get("events"):
                events = ", ".join(f"{k}:{v}" for k, v in details["events"].items())
                print(f"  events: {events}")
            if details.get("unknown_events"):
                print(f"  unknown events: {', '.join(details['unknown_events'])}")
            if details.get("error"):
                print(f"  error: {details['error']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
