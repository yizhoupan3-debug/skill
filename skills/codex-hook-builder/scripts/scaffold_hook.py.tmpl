#!/usr/bin/env python3
"""Scaffold a project-local Codex hook from bundled templates."""

from __future__ import annotations

import argparse
import json
import re
from pathlib import Path
from typing import Any


TEMPLATE_BY_EVENT = {
    "SessionStart": "session_start.py.tmpl",
    "UserPromptSubmit": "user_prompt_submit.py.tmpl",
    "PreToolUse": "pre_tool_use_policy.py.tmpl",
    "PermissionRequest": "permission_request.py.tmpl",
    "PostToolUse": "post_tool_use_review.py.tmpl",
    "Stop": "stop_gate.py.tmpl",
}


def slugify(value: str) -> str:
    slug = re.sub(r"[^a-zA-Z0-9]+", "-", value).strip("-").lower()
    return slug or "codex-hook"


def load_hooks(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {"hooks": {}}
    data = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(data, dict):
        raise ValueError(f"{path} must contain a JSON object")
    hooks = data.setdefault("hooks", {})
    if not isinstance(hooks, dict):
        raise ValueError(f"{path}: $.hooks must be an object")
    return data


def ensure_feature_flag(config_path: Path) -> bool:
    if config_path.exists():
        text = config_path.read_text(encoding="utf-8")
        lines = text.splitlines()
        features_start: int | None = None
        features_end = len(lines)
        for index, line in enumerate(lines):
            if re.match(r"^\s*\[features\]\s*$", line):
                features_start = index
                continue
            if features_start is not None and index > features_start and re.match(r"^\s*\[[^\]]+\]\s*$", line):
                features_end = index
                break

        if features_start is None:
            suffix = "" if text.endswith("\n") else "\n"
            config_path.write_text(f"{text}{suffix}\n[features]\ncodex_hooks = true\n", encoding="utf-8")
            return True

        for index in range(features_start + 1, features_end):
            if re.match(r"^\s*codex_hooks\s*=", lines[index]):
                if re.match(r"^\s*codex_hooks\s*=\s*true\s*($|#)", lines[index]):
                    return False
                lines[index] = "codex_hooks = true"
                config_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
                return True

        insert_at = features_start + 1
        lines.insert(insert_at, "codex_hooks = true")
        config_path.write_text("\n".join(lines) + "\n", encoding="utf-8")
        return True

    config_path.write_text("[features]\ncodex_hooks = true\n", encoding="utf-8")
    return True


def validate_existing_group(groups: Any, event: str) -> list[dict[str, Any]]:
    if not isinstance(groups, list):
        raise ValueError(f"$.hooks.{event} must be a list")
    for index, group in enumerate(groups):
        if not isinstance(group, dict):
            raise ValueError(f"$.hooks.{event}[{index}] must be an object")
        handlers = group.get("hooks")
        if not isinstance(handlers, list) or not handlers:
            raise ValueError(f"$.hooks.{event}[{index}].hooks must be a non-empty list")
    return groups


def validate_config_can_be_enabled(config_path: Path) -> None:
    if not config_path.exists():
        return
    text = config_path.read_text(encoding="utf-8")
    features_headers = [
        line for line in text.splitlines() if re.match(r"^\s*\[features\]\s*$", line)
    ]
    if len(features_headers) > 1:
        raise ValueError(f"{config_path} already has duplicate [features] tables")
    for line in text.splitlines():
        if re.match(r"^\s*codex_hooks\s*=", line):
            return


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--repo", default=".", help="Project root. Defaults to cwd.")
    parser.add_argument("--event", required=True, choices=sorted(TEMPLATE_BY_EVENT))
    parser.add_argument("--name", help="Hook name. Defaults to the event name.")
    parser.add_argument("--matcher", default="*", help="Matcher regex or *. Defaults to *.")
    parser.add_argument("--timeout", type=float, default=10.0)
    parser.add_argument(
        "--enable-feature",
        action="store_true",
        help="Create or append .codex/config.toml with codex_hooks enabled.",
    )
    args = parser.parse_args()

    repo = Path(args.repo).expanduser().resolve()
    codex_dir = repo / ".codex"
    hooks_dir = codex_dir / "hooks"
    name = slugify(args.name or args.event)
    skill_root = Path(__file__).resolve().parents[1]
    template = skill_root / "assets" / "templates" / TEMPLATE_BY_EVENT[args.event]
    script_path = hooks_dir / f"{name}.py"
    if script_path.exists():
        raise SystemExit(f"Refusing to overwrite existing hook script: {script_path}")
    hooks_json = codex_dir / "hooks.json"
    try:
        data = load_hooks(hooks_json)
        hooks = data.setdefault("hooks", {})
        event_groups = validate_existing_group(hooks.setdefault(args.event, []), args.event)
        config_path = codex_dir / "config.toml"
        if args.enable_feature:
            validate_config_can_be_enabled(config_path)
    except (json.JSONDecodeError, ValueError) as exc:
        raise SystemExit(f"Cannot scaffold hook: {exc}") from exc

    hook_command = f'python3 "$(git rev-parse --show-toplevel)/.codex/hooks/{name}.py"'
    event_groups.append(
        {
            "matcher": args.matcher,
            "hooks": [
                {
                    "type": "command",
                    "command": hook_command,
                    "timeout": args.timeout,
                    "statusMessage": f"Running {name} hook",
                }
            ],
        }
    )

    codex_dir.mkdir(exist_ok=True)
    hooks_dir.mkdir(exist_ok=True)
    script_path.write_text(template.read_text(encoding="utf-8"), encoding="utf-8")
    script_path.chmod(0o755)
    hooks_json.write_text(json.dumps(data, indent=2) + "\n", encoding="utf-8")

    changed_config = False
    if args.enable_feature:
        changed_config = ensure_feature_flag(config_path)

    print(json.dumps({
        "script": str(script_path),
        "hooks_json": str(hooks_json),
        "config_changed": changed_config,
    }, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
