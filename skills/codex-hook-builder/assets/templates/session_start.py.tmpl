#!/usr/bin/env python3
"""Add concise project guidance at Codex session start."""

from __future__ import annotations

import json
from pathlib import Path
import sys


def main() -> int:
    event = json.load(sys.stdin)
    cwd = Path(event.get("cwd") or ".").resolve()
    docs = [
        "AGENTS.md",
        "DESIGN.md",
        "README.md",
        "package.json",
        "pyproject.toml",
        "Cargo.toml",
    ]
    present = [name for name in docs if (cwd / name).exists()]
    if not present:
        return 0

    message = (
        "Before making project changes, inspect the relevant local guidance first. "
        f"Detected at repo root: {', '.join(present[:6])}."
    )
    print(json.dumps({
        "hookSpecificOutput": {
            "hookEventName": "SessionStart",
            "additionalContext": message,
        }
    }))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
