#!/usr/bin/env python3
"""Deny high-risk commands before supported tools run."""

from __future__ import annotations

import json
import re
import shlex
import sys


BLOCK_PATTERNS = [
    (re.compile(r"\brm\s+-[^;\n]*[rf][^;\n]*\s+(/|~|\$HOME)(\s|$)"), "Refuses recursive deletion of root or home."),
    (re.compile(r"\bgit\s+reset\s+--hard\b"), "Refuses git reset --hard without explicit human handling."),
    (re.compile(r"\bgit\s+clean\s+-[^;\n]*[fdx]"), "Refuses destructive git clean by default."),
    (re.compile(r"\bchmod\s+-R\s+777\b"), "Refuses chmod -R 777."),
    (re.compile(r"\bcurl\b[^|;\n]*\|\s*(sh|bash)\b"), "Refuses curl-to-shell execution."),
    (re.compile(r"\bwget\b[^|;\n]*\|\s*(sh|bash)\b"), "Refuses wget-to-shell execution."),
    (re.compile(r"\bsudo\b"), "Refuses sudo from automated hook policy."),
]


def command_from(event: dict) -> str:
    tool_input = event.get("tool_input")
    if isinstance(tool_input, dict):
        command = tool_input.get("command") or tool_input.get("cmd")
        if isinstance(command, str):
            return command
    for key in ("command", "cmd"):
        value = event.get(key)
        if isinstance(value, str):
            return value
    return ""


def main() -> int:
    event = json.load(sys.stdin)
    command = command_from(event)
    normalized = " ".join(shlex.split(command)) if command else ""
    for pattern, reason in BLOCK_PATTERNS:
        if pattern.search(command) or pattern.search(normalized):
            print(json.dumps({
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": reason,
                }
            }))
            return 0
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
