{
  "schema_version": "framework-runtime-registry-schema-v1",
  "scope": "execution-critical-fields-only",
  "host_ids": [
    "codex-cli",
    "codex-app",
    "cursor",
    "claude-code",
    "qoder"
  ],
  "projection_status_values": [
    "implemented",
    "declared",
    "planned",
    "retired"
  ],
  "required_host_metadata_fields": [
    "install_tool",
    "projection_status",
    "installable",
    "host_entrypoints"
  ],
  "install_tools": [
    "codex",
    "cursor",
    "claude",
    "qoder"
  ],
  "framework_command_required_fields": [
    "canonical_owner",
    "skill_path"
  ],
  "harness_capability_policy": {
    "core_always": [
      "hot_runtime_routing",
      "l2_continuity_contract"
    ],
    "cli_agent_hook_baseline": [
      "closeout_evidence_hooks",
      "review_gate_router_observation"
    ]
  },
  "harness_capability_exception_status_values": [
    "unsupported"
  ],
  "registry_review_gate_notes": "RUNTIME_REGISTRY.json must include review_gate.deep_gate_lanes (non-empty string array). Consumed by router-rs for Cursor/Codex REVIEW_GATE countable lanes."
}
