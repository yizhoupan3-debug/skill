{
  "version": 1,
  "_doc": "Cross-workspace bootstrap: hooks call configs/framework/cursor-router-rs-hook.sh, which probes release/debug/PATH (or ROUTER_RS_BIN). Critical gate events fail-closed when router-rs is unavailable; telemetry/format events fail-open. repo-root is CURSOR_WORKSPACE_ROOT so artifacts/.cursor/hook-state stay in the opened folder.",
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "_doc": "Goal/autopilot + review gate",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" BeforeSubmitPrompt",
        "timeout": 20
      }
    ],
    "stop": [
      {
        "_doc": "Goal follow-up + gates",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" Stop",
        "timeout": 20
      }
    ],
    "sessionStart": [
      {
        "_doc": "Compact project briefing at session start",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" SessionStart",
        "timeout": 5
      }
    ],
    "sessionEnd": [
      {
        "_doc": "Session end cleanup + terminal scope",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" SessionEnd",
        "timeout": 15
      }
    ],
    "postToolUse": [
      {
        "_doc": "PostToolUse + rust-lint",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" PostToolUse",
        "timeout": 60
      }
    ],
    "afterAgentResponse": [
      {
        "_doc": "Agent response signal scan",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" AfterAgentResponse",
        "timeout": 20
      }
    ],
    "beforeShellExecution": [
      {
        "_doc": "Shell lifecycle (before)",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" BeforeShellExecution",
        "timeout": 15
      }
    ],
    "afterShellExecution": [
      {
        "_doc": "Shell lifecycle (after)",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" AfterShellExecution",
        "timeout": 15
      }
    ],
    "afterFileEdit": [
      {
        "_doc": "rustfmt on .rs after agent edits",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" AfterFileEdit",
        "timeout": 10
      }
    ],
    "preCompact": [
      {
        "_doc": "Token usage + PreCompact",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" PreCompact",
        "timeout": 25
      }
    ],
    "subagentStart": [
      {
        "_doc": "Review gate subagent phase + throttle",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" SubagentStart",
        "timeout": 20
      }
    ],
    "subagentStop": [
      {
        "_doc": "Subagent end phase",
        "command": "/usr/bin/env bash \"${SKILL_FRAMEWORK_ROOT:-${CURSOR_WORKSPACE_ROOT:-$PWD}}/configs/framework/cursor-router-rs-hook.sh\" SubagentStop",
        "timeout": 20
      }
    ]
  }
}
