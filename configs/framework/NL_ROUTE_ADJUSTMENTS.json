      "record": {
        "slug": "paper-workbench"
      }
    },
    {
      "when": {
        "all": [
          {
            "signal": "has_pr_triage_summary_context"
          },
          {
            "not": {
              "signal": "has_ci_failure_context"
            }
          }
        ]
