      "record": {
        "slug": "gh-fix-ci"
      }
    },
    {
      "when": {
        "signal": "has_paper_workbench_frontdoor_context"
      },
      "action": {
        "type": "boost",
        "delta": 54.0,
        "reason": "Paper-workbench boost applied: manuscript front-door workflow or next-step triage detected."
      },
      "record": {
        "slug": "paper-workbench"
      }
    },
    {
      "when": {
        "signal": "has_paper_review_judgment_context"
      },
      "action": {
        "type": "boost",
        "delta": 36.0,
        "reason": "Paper-workbench boost applied: paper review judgment with optional external calibration detected."
      },
      "record": {
        "slug": "paper-workbench"
      }
    },
    {
      "when": {
        "signal": "has_paper_figure_layout_review_context"
