{
  "mcpServers": {
    "framework-mcp": {
      "command": "./scripts/router-rs/target/release/router-rs",
      "args": [
        "--framework-mcp-stdio",
        "--repo-root",
        "../.."
      ],
      "cwd": "../.."
    },
    "browser-mcp": {
      "command": "bash",
      "args": [
        "./tools/browser-mcp/scripts/start_browser_mcp.sh"
      ],
      "cwd": "../.."
    }
  }
}
