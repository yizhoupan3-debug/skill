{
  "mcpServers": {
    "framework-mcp": {
      "command": "./scripts/router-rs/target/release/router-rs",
      "args": [
        "--framework-mcp-stdio",
        "--repo-root",
        "../.."
      ],
      "cwd": "../.."
    },
    "browser-mcp": {
      "command": "node",
      "args": [
        "./tools/browser-mcp/dist/index.js"
      ],
      "cwd": "./tools/browser-mcp"
    }
  }
}
