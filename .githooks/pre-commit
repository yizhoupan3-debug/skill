#!/bin/sh
set -eu

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

NEEDS_SKILL_COMPILE=0
for path in $STAGED_FILES; do
    case "$path" in
        skills/*/SKILL.md|skills/.system/*/SKILL.md|skills/SKILL_SOURCE_MANIFEST.json|scripts/skill-compiler-rs/*|scripts/skill-compiler-rs/*/*)
            NEEDS_SKILL_COMPILE=1
            ;;
    esac
done

if [ "$NEEDS_SKILL_COMPILE" != "1" ]; then
    exit 0
fi

LOG_FILE=$(mktemp "${TMPDIR:-/tmp}/skill-pre-commit.XXXXXX")
trap 'rm -f "$LOG_FILE"' EXIT

if ! cargo run --quiet --manifest-path scripts/skill-compiler-rs/Cargo.toml -- \
  --skills-root skills \
  --source-manifest skills/SKILL_SOURCE_MANIFEST.json \
  --apply >"$LOG_FILE" 2>&1; then
    echo "[pre-commit] skill compiler failed; rerun this command for details:"
    echo "  cargo run --manifest-path scripts/skill-compiler-rs/Cargo.toml -- --skills-root skills --source-manifest skills/SKILL_SOURCE_MANIFEST.json --apply"
    tail -n 40 "$LOG_FILE"
    exit 1
fi

if ! git diff --quiet -- \
  skills/SKILL_APPROVAL_POLICY.json \
  skills/SKILL_LOADOUTS.json \
  skills/SKILL_MANIFEST.json \
  skills/SKILL_ROUTING_INDEX.md \
  skills/SKILL_ROUTING_REGISTRY.md \
  skills/SKILL_ROUTING_RUNTIME.json \
  skills/SKILL_SHADOW_MAP.json \
  skills/SKILL_TIERS.json \
  configs/framework/FRAMEWORK_SURFACE_POLICY.json; then
    echo "[pre-commit] skill compiler updated generated routing artifacts."
    echo "Stage those files, then commit again:"
    echo "  git add skills/SKILL_APPROVAL_POLICY.json skills/SKILL_LOADOUTS.json skills/SKILL_MANIFEST.json skills/SKILL_ROUTING_INDEX.md skills/SKILL_ROUTING_REGISTRY.md skills/SKILL_ROUTING_RUNTIME.json skills/SKILL_SHADOW_MAP.json skills/SKILL_TIERS.json configs/framework/FRAMEWORK_SURFACE_POLICY.json"
    exit 1
fi
