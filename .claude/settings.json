{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "allowedMcpServers": [
    {
      "serverName": "browser-mcp"
    },
    {
      "serverName": "framework-mcp"
    },
    {
      "serverName": "openaiDeveloperDocs"
    }
  ],
  "hooks": {
    "ConfigChange": [
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh config-change",
            "type": "command"
          }
        ],
        "matcher": "project_settings"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Edit(/framework_runtime/src/**)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "MultiEdit(/framework_runtime/src/**)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Write(/framework_runtime/src/**)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Edit(/scripts/router-rs/src/**)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "MultiEdit(/scripts/router-rs/src/**)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Write(/scripts/router-rs/src/**)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Edit(/tests/test_cli_host_entrypoints.py)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "MultiEdit(/tests/test_cli_host_entrypoints.py)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Write(/tests/test_cli_host_entrypoints.py)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Edit(/tests/test_codex_omx_hook_bridge.py)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "MultiEdit(/tests/test_codex_omx_hook_bridge.py)",
            "timeout": 8,
            "type": "command"
          },
          {
            "async": true,
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh post-tool-audit",
            "if": "Write(/tests/test_codex_omx_hook_bridge.py)",
            "timeout": 8,
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/AGENT.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/AGENT.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/AGENT.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/AGENTS.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/AGENTS.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/AGENTS.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/CLAUDE.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/CLAUDE.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/CLAUDE.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/GEMINI.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/GEMINI.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/GEMINI.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.gemini/settings.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.gemini/settings.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.gemini/settings.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.claude/settings.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.claude/settings.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.claude/settings.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.claude/agents/README.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.claude/agents/README.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.claude/agents/README.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.claude/hooks/README.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.claude/hooks/README.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.claude/hooks/README.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.claude/hooks/*.sh)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.claude/hooks/*.sh)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.claude/hooks/*.sh)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.claude/commands/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.claude/commands/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.claude/commands/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.codex/hooks.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.codex/hooks.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.codex/hooks.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.codex/host_entrypoints_sync_manifest.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.codex/host_entrypoints_sync_manifest.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.codex/host_entrypoints_sync_manifest.json)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Edit(/.codex/memory/CLAUDE_MEMORY.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "MultiEdit(/.codex/memory/CLAUDE_MEMORY.md)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Write(/.codex/memory/CLAUDE_MEMORY.md)",
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      },
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*AGENT.md*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*AGENTS.md*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*CLAUDE.md*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*GEMINI.md*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.gemini/settings.json*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.claude/settings.json*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.claude/agents/README.md*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.claude/hooks/*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.claude/commands/*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.codex/hooks.json*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.codex/host_entrypoints_sync_manifest.json*)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use",
            "if": "Bash(*.codex/memory/CLAUDE_MEMORY.md*)",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Edit(/framework_runtime/src/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "MultiEdit(/framework_runtime/src/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Write(/framework_runtime/src/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Edit(/scripts/router-rs/src/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "MultiEdit(/scripts/router-rs/src/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Write(/scripts/router-rs/src/**)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Edit(/tests/test_cli_host_entrypoints.py)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "MultiEdit(/tests/test_cli_host_entrypoints.py)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Write(/tests/test_cli_host_entrypoints.py)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Edit(/tests/test_codex_omx_hook_bridge.py)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "MultiEdit(/tests/test_codex_omx_hook_bridge.py)",
            "type": "command"
          },
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh pre-tool-use-quality",
            "if": "Write(/tests/test_codex_omx_hook_bridge.py)",
            "type": "command"
          }
        ],
        "matcher": "Edit|MultiEdit|Write"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh session-end",
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh stop-failure",
            "type": "command"
          }
        ],
        "matcher": "invalid_request|server_error|max_output_tokens|rate_limit|authentication_failed|billing_error|unknown"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "sh \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run.sh user-prompt-submit",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(sed -n *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(python3 scripts/check_skills.py --verify-sync)",
      "Bash(python3 scripts/materialize_cli_host_entrypoints.py)",
      "Bash(python3 -m pytest *)",
      "Bash(python3 -m compileall *)",
      "Bash(cargo test *)",
      "Bash(cargo run --manifest-path ./scripts/router-rs/Cargo.toml --release -- *)",
      "Bash(./scripts/router-rs/target/release/router-rs *)",
      "Bash(./scripts/router-rs/target/debug/router-rs *)",
      "Bash(*scripts/router-rs/target/release/router-rs *)",
      "Bash(*scripts/router-rs/target/debug/router-rs *)",
      "Bash(cargo run --manifest-path *scripts/router-rs/Cargo.toml --release -- *)",
      "Bash(python3 scripts/runtime_background_cli.py *)",
      "Bash(cmp -s TRACE_METADATA.json artifacts/current/TRACE_METADATA.json)",
      "Bash(./tools/browser-mcp/scripts/start_browser_mcp.sh *)",
      "Bash(bash ./tools/browser-mcp/scripts/start_browser_mcp.sh *)"
    ]
  }
}
